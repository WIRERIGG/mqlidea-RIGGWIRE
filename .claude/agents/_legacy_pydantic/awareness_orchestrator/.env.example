# Awareness Orchestrator Configuration

# ============================
# LLM Provider Configuration
# ============================

# Provider: anthropic or openai
LLM_PROVIDER=anthropic

# API Key (REQUIRED)
LLM_API_KEY=your_anthropic_api_key_here

# Model to use
LLM_MODEL=claude-sonnet-4-5-20250929

# Base URL (optional, for custom endpoints)
# LLM_BASE_URL=

# ============================
# Orchestrator Configuration
# ============================

# Maximum number of agents to run
MAX_AGENTS=3

# Enable parallel agent execution
ENABLE_PARALLEL=true

# Depth of context enrichment
CONTEXT_DEPTH=3

# ============================
# Learning Configuration
# ============================

# Path to learning database
LEARNING_DB_PATH=.learning/orchestrator.json

# Enable pattern learning
ENABLE_LEARNING=true

# ============================
# Logging Configuration
# ============================

# Directory for logs
LOG_DIR=/tmp/awareness_orchestrator_logs

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
