# Blitzfire Code Agent Configuration Template
# Copy this file to .env and configure your settings

# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================

# Primary LLM provider (openai, anthropic, gemini, ollama)
LLM_PROVIDER=openai

# API key for your chosen provider
LLM_API_KEY=your-api-key-here

# Model to use
LLM_MODEL=gpt-4o-mini

# Base URL for API (leave default unless using custom endpoint)
LLM_BASE_URL=https://api.openai.com/v1

# Alternative: Anthropic Claude
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-your-key-here
# LLM_MODEL=claude-3-sonnet-20240229

# Alternative: Google Gemini
# LLM_PROVIDER=gemini
# LLM_API_KEY=your-gemini-key-here
# LLM_MODEL=gemini-pro

# Alternative: Local Ollama
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=llama2

# =============================================================================
# EXTERNAL SERVICE CONFIGURATION
# =============================================================================

# Godbolt Compiler Explorer
GODBOLT_BASE_URL=https://godbolt.org
GODBOLT_TIMEOUT=30
GODBOLT_CACHE_TTL=3600

# Docker Configuration
DOCKER_ENABLED=true
DOCKER_IMAGE=blitzfire/benchmark:latest
DOCKER_TIMEOUT=120
DOCKER_MEMORY_LIMIT=2g

# =============================================================================
# PROJECT INTEGRATION
# =============================================================================

# Project root directory
PROJECT_ROOT=/IdeaProjects/wire_ground

# Compiler paths
CLANG_BINARY_PATH=/usr/bin/clang++
CLANG_TIDY_BINARY_PATH=/usr/bin/clang-tidy

# =============================================================================
# AGENT BEHAVIOR CONFIGURATION
# =============================================================================

# Default optimization mode (general, hft, embedded, game)
BLITZFIRE_MODE=general

# Target architecture
DEFAULT_ARCHITECTURE=x86_64

# Compiler optimization level
DEFAULT_OPTIMIZATION_LEVEL=-O3

# Safety constraints (low, medium, high)
SAFETY_LEVEL=high

# =============================================================================
# PERFORMANCE AND CACHING
# =============================================================================

# Cache time-to-live in seconds
ANALYSIS_CACHE_TTL=1800
BENCHMARK_CACHE_TTL=7200

# Resource limits
MAX_CODE_SIZE=50000
MAX_ANALYSIS_TIME=30

# =============================================================================
# HFT-SPECIFIC SETTINGS
# =============================================================================

# HFT audit depth (basic, standard, comprehensive)
HFT_AUDIT_LEVEL=comprehensive

# Enable specific HFT checks
HFT_OVERFLOW_CHECKS=true
HFT_RACE_DETECTION=true

# =============================================================================
# DEBUGGING AND LOGGING
# =============================================================================

# Enable debug logging
DEBUG_MODE=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log file path (empty for console only)
LOG_FILE=