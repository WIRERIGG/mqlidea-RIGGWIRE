# Blitzfire C++ Optimizer Agent Configuration

# LLM Provider Configuration
LLM_PROVIDER=anthropic
LLM_API_KEY=your_api_key_here
LLM_MODEL=claude-3-sonnet-20241022
LLM_BASE_URL=https://api.anthropic.com/v1

# Agent Configuration
BLITZFIRE_DB_PATH=./blitzfire_optimizer.db
COMPILER_PATH=/usr/bin/g++
BENCHMARK_TIMEOUT=60
OPTIMIZATION_LOG_LEVEL=INFO
MAX_OPTIMIZATION_ITERATIONS=5

# Performance Analysis Configuration
TARGET_ARCHITECTURES=x86_64,native
COMPILER_FLAGS=-O3,-march=native,-mtune=native,-flto,-DNDEBUG
BENCHMARK_ITERATIONS=1000
PERFORMANCE_THRESHOLD=1.1

# Project Settings
PROJECT_ROOT=/IdeaProjects/wire_ground
ENABLE_LEARNING_MODE=true
CACHE_OPTIMIZATION_RESULTS=true
GENERATE_BENCHMARKS=true
SAFETY_CHECKS_ENABLED=true

# Advanced Features
SIMD_OPTIMIZATION=true
PARALLEL_OPTIMIZATION=true
MEMORY_OPTIMIZATION=true
TEMPLATE_METAPROGRAMMING=true