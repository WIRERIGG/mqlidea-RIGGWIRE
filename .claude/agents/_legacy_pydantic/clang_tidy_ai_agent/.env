# Clang-Tidy AI Agent Configuration
# For production validation testing

# LLM Configuration (required for agent loading)
LLM_PROVIDER=test
LLM_API_KEY=test-key-for-validation
LLM_MODEL=test-model
LLM_BASE_URL=http://localhost:8000

# Agent Settings
CLANG_TIDY_BINARY_PATH=/usr/bin/clang-tidy
PROJECT_ROOT=/IdeaProjects/wire_ground
ENABLE_LEARNING_MODE=true
CACHE_ANALYSIS_RESULTS=true
CLANG_TIDY_LOG_LEVEL=INFO
CLANG_TIDY_MAX_WARNINGS=100