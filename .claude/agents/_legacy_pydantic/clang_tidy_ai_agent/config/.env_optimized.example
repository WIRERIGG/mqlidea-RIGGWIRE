# Optimized Clang-Tidy AI Agent Configuration

# Core Configuration
CLANG_TIDY_BINARY_PATH=/usr/bin/clang-tidy
PROJECT_ROOT=/IdeaProjects/wire_ground
CACHE_DIR=/tmp/clang_tidy_cache

# LLM Configuration
LLM_PROVIDER=anthropic
LLM_API_KEY=your_api_key_here
LLM_MODEL=claude-3-sonnet-20240229
LLM_MAX_RETRIES=3
LLM_TIMEOUT=30

# Fallback LLM (optional)
FALLBACK_LLM_PROVIDER=openai
FALLBACK_LLM_API_KEY=your_fallback_api_key_here
FALLBACK_LLM_MODEL=gpt-4

# Performance Settings
MAX_CONCURRENT_ANALYSES=4
CACHE_TTL_SECONDS=3600
SUBPROCESS_TIMEOUT=30
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60

# Feature Flags
ENABLE_CACHING=true
ENABLE_KNOWLEDGE_BASE=true
ENABLE_PROGRESS_TRACKING=true
ENABLE_PERFORMANCE_METRICS=true
ENABLE_MULTI_COMPILER_VALIDATION=true

# Database Configuration
SQLITE_DB_PATH=/tmp/clang_tidy_ai.db
KNOWLEDGE_BASE_PATH=/tmp/clang_tidy_knowledge.db

# Compiler Paths
GCC_PATH=/usr/bin/g++
CLANG_PATH=/usr/bin/clang++
CMAKE_PATH=/usr/bin/cmake

# Integration Settings
GIT_AUTO_COMMIT=false
CMAKE_BUILD_DIR=cmake-build-debug
AUDIT_LOG_PATH=/tmp/clang_tidy_audit.log

# Clang-Tidy Settings
DEFAULT_CHECKS=readability-*,performance-*,modernize-*,bugprone-*
FIX_CATEGORIES=readability-braces-around-statements,modernize-use-nullptr