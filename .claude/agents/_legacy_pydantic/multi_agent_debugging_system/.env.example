# Multi-Agent Debugging System Environment Configuration

# LLM Configuration (Required)
LLM_PROVIDER=openai
LLM_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4
LLM_BASE_URL=https://api.openai.com/v1

# Analysis Configuration
ANALYSIS_OUTPUT_DIR=./debug_analysis_output
ANALYSIS_TIMEOUT=300
MAX_PARALLEL_TOOLS=4
CORRELATION_THRESHOLD=0.7

# Tool Paths (Optional - will auto-detect)
GDB_PATH=gdb
STRACE_PATH=strace
LTRACE_PATH=ltrace
PERF_PATH=perf
CPPCHECK_PATH=cppcheck
CLANG_TIDY_PATH=clang-tidy
VALGRIND_PATH=valgrind

# Build Configuration
BUILD_DIR=./build
COMPILER=g++
# BUILD_FLAGS is a space-separated list
BUILD_FLAGS=-g -O0 -Wall

# Logging
LOG_LEVEL=INFO
DEBUG=false