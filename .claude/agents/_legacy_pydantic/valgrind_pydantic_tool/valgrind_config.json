{
  "tool": "memcheck",
  "timeout": 1800,
  "xml_output": true,
  "verbose": false,
  "quiet": false,
  "num_callers": 12,
  "error_limit": true,
  "show_error_list": true,
  "show_below_main": false,
  "suppressions": [
    "/IdeaProjects/wire_ground/valgrind_suppressions.supp"
  ],
  "leak_check": "full",
  "show_reachable": true,
  "show_possibly_lost": true,
  "track_origins": true,
  "track_fds": false,
  "partial_loads_ok": true,
  "undef_value_errors": true,
  "history_level": "full",
  "check_stack_refs": true,
  "cache_sim": true,
  "branch_sim": true,
  "heap": true,
  "heap_admin": 8,
  "stacks": false,
  "depth": 30,
  "threshold": 1.0,
  "peak_inaccuracy": 1.0,
  "time_unit": "i",
  "detailed_freq": 10,
  "max_snapshots": 100,
  "args": [],
  "enable_ai": false,
  "llm_provider": "openai",
  "llm_model": "gpt-4"
}