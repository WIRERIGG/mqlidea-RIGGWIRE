<idea-plugin require-restart="true"
             url="https://limemojito.com/articles/limemojito-mql-idea">
    <id>com.limemojito.oss.mqlidea</id>
    <name>Lime MQL Editing</name>
    <version>2026.1.0</version>
    <vendor email="admin@limemojito.com"
            url="https://limemojito.com/">
        Lime Mojito Pty Ltd
    </vendor>
    <description>
        <![CDATA[
         <p><b>MetaQuotes MQL4 and MQL5 support for IntelliJ IDEA.</b></p>
         <p><i>Forked from the original mqlidea plugin by investorflow.ru and updated for the latest IDE.</i></p>
         <p>
            <b>Setup:</b>
            <ol>
             <li>Please Uninstall any other versions of the MQLIdea plugin (such as investorflow.ru)</li>
             <li>Restart IntelliJ IDEA.</li>
             <li>Install the Lime MQL Editing plugin from the Marketplace</li>
             <li>Restart IntelliJ IDEA.</li>
            </ol>
         </p>
         <p>
           <b>Supports:</b>
           <ul>
             <li>MQL Syntax highlighting.</li>
             <li>Code completion and navigation for MQL4 and MQL5</li>
             <li>Quick documentation in English and Russian (see settings).</li>
           </ul>
         </p>
         <p>
           <b>Not Supported:</b>
           <ul>
             <li>Code formatting</li>
             <li>Code refactoring</li>
             <li>Debugging</li>
             <li>Launching MQL compiler on Windows, Linux</li>
           </ul>
         </p>
         ]]>
    </description>

    <change-notes>
        <![CDATA[
            <ul>
             <li>Version 2026.1.0 – Initial release with basic MQL4 and MQL5 support from fork of mqlidea investorflow.ru plugin</li>
            </ul>
         ]]>
    </change-notes>

    <idea-version since-build="253.30387"/>

    <depends>com.intellij.modules.lang</depends>

    <actions>
        <action id="NewMQL4File" class="com.limemojito.oss.mql.action.CreateMQL4FileAction">
            <add-to-group group-id="NewGroup" anchor="before" relative-to-action="NewFromTemplate"/>
        </action>
        <action id="NewMQL5File" class="com.limemojito.oss.mql.action.CreateMQL5FileAction">
            <add-to-group group-id="NewGroup" anchor="before" relative-to-action="NewFromTemplate"/>
        </action>
    </actions>

    <!-- TODO This needs to updated as deprecated -->
    <application-components>
        <component>
            <interface-class>com.limemojito.oss.mql.settings.MQL4PluginSettings</interface-class>
            <implementation-class>com.limemojito.oss.mql.settings.MQL4PluginSettingsImpl</implementation-class>
        </component>
    </application-components>


    <extensions defaultExtensionNs="com.intellij">
        <fileType name="MQL4 File"
                  implementationClass="com.limemojito.oss.mql.MQL4FileType"
                  fieldName="INSTANCE"
                  language="MQL4"
                  extensions="mq4;mqh;mql4"
        />
        <fileType name="MQL5 File"
                  implementationClass="com.limemojito.oss.mql.MQL5FileType"
                  fieldName="INSTANCE"
                  language="MQL4"
                  extensions="mq5;mqh;mql5"
        />

        <lang.parserDefinition language="MQL4"
                               implementationClass="com.limemojito.oss.mql.parser.MQL4ParserDefinition"/>
        <lang.syntaxHighlighterFactory language="MQL4"
                                       implementationClass="com.limemojito.oss.mql.editor.MQL4SyntaxHighlighter$MQL4SyntaxHighlighterFactory"/>
        <lang.commenter language="MQL4" implementationClass="com.limemojito.oss.mql.editor.MQL4Commenter"/>
        <lang.documentationProvider language="MQL4"
                                    implementationClass="com.limemojito.oss.mql.doc.MQL4DocumentationProvider"/>
        <lang.braceMatcher language="MQL4" implementationClass="com.limemojito.oss.mql.editor.MQL4BraceMatcher"/>
        <lang.foldingBuilder language="MQL4" implementationClass="com.limemojito.oss.mql.editor.MQL4FoldingBuilder"/>
        <completion.contributor language="MQL4"
                                implementationClass="com.limemojito.oss.mql.editor.codecompletion.MQL4CompletionContributor"/>

        <!-- sdk -->
        <sdkType implementation="com.limemojito.oss.mql.sdk.MQL4SdkType"/>

        <!--build runner-->
        <programRunner implementation="com.limemojito.oss.mql.runconfig.MQL4CompilerRunner"/>
        <runConfigurationProducer
                implementation="com.limemojito.oss.mql.runconfig.MQL4RunCompilerConfigurationProducer"/>
        <configurationType implementation="com.limemojito.oss.mql.runconfig.MQL4RunCompilerConfigurationType"/>

        <!--
        https://confluence.jetbrains.com/display/IDEADEV/Customizing+the+IDEA+Settings+Dialog
        https://sites.google.com/site/malenkov/java/150403
        -->
        <!--suppress PluginXmlI18n -->
        <projectConfigurable id="settings.mql4"
                             groupId="language"
                             displayName="Lime Mojito MQL Idea"
                             instance="com.limemojito.oss.mql.settings.MQL4PluginSettingsPanel"/>

        <!--Inspections-->
        <!--suppress PluginXmlI18n -->
        <localInspection language="MQL4" groupName="MQL4 inspections" enabledByDefault="true" level="WARNING"
                         displayName="Preprocessor #property element"
                         implementationClass="com.limemojito.oss.mql.inspection.PreprocessorPropertyInspection"/>

        <!--Structure view-->
        <lang.psiStructureViewFactory language="MQL4"
                                      implementationClass="com.limemojito.oss.mql.structure.MQL4StructureViewBuilderFactory"/>

        <!--Indexing -->
        <stubElementTypeHolder class="com.limemojito.oss.mql.psi.stub.MQL4StubElements" externalIdPrefix="LMMI"/>
        <stubIndex implementation="com.limemojito.oss.mql.index.MQL4ClassNameIndex"/>
        <stubIndex implementation="com.limemojito.oss.mql.index.MQL4FunctionNameIndex"/>

        <gotoClassContributor implementation="com.limemojito.oss.mql.index.MQL4GotoClassContributor"/>
        <gotoSymbolContributor implementation="com.limemojito.oss.mql.index.MQL4GotoSymbolContributor"/>
        <gotoDeclarationHandler implementation="com.limemojito.oss.mql.index.MQL4GotoDeclarationHandler"/>

    </extensions>
</idea-plugin>
