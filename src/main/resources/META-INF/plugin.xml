<idea-plugin require-restart="true"
             url="https://github.com/WIRERIGG">
    <id>io.riggwire.mql</id>
    <name>RIGGWIRE MQL</name>
    <version>2026.1.0</version>
    <vendor url="https://github.com/WIRERIGG">RIGGWIRE Trading Systems</vendor>
    <description>
        <![CDATA[
         <p><b>RIGGWIRE MQL &mdash; MetaQuotes MQL4 &amp; MQL5 support for IntelliJ IDEA, with AI code healing.</b></p>
         <p>Professional MQL4/MQL5 language support: syntax highlighting, code completion and
            navigation, quick documentation (English &amp; Russian), 80 code-safety inspections, and
            an optional AI code-healing pipeline (Grok analysis &rarr; Claude fixes).</p>
         <p><i>A fork of the &quot;Lime MQL Editing&quot; plugin by Lime Mojito Pty Ltd (originally the
             <a href="https://plugins.jetbrains.com/plugin/9291-mql-idea">mqlidea plugin by investflow.ru</a>),
             independently maintained by RIGGWIRE Trading Systems. Licensed under GPL-3.0.</i></p>
         <p>
            <b>Setup:</b>
            <ol>
             <li>Uninstall any other MQL/MQLIdea plugins (e.g. investflow.ru or Lime MQL Editing).</li>
             <li>Restart IntelliJ IDEA.</li>
             <li>Install <b>RIGGWIRE MQL</b> from the Marketplace.</li>
             <li>Restart IntelliJ IDEA.</li>
            </ol>
         </p>
         <p>
           <b>Supports:</b>
           <ul>
             <li>MQL4 &amp; MQL5 syntax highlighting.</li>
             <li>Code completion and navigation.</li>
             <li>Quick documentation in English and Russian (see settings).</li>
             <li>80 code-safety inspections.</li>
             <li>AI code healing (opt-in; bring your own Grok &amp; Claude keys).</li>
           </ul>
         </p>
         <p>
           <b>Not Supported:</b>
           <ul>
             <li>Code formatting</li>
             <li>Code refactoring</li>
             <li>Debugging</li>
             <li>Launching the MQL compiler on Windows, Linux</li>
           </ul>
         </p>
         ]]>
    </description>

    <change-notes>
        <![CDATA[
            <ul>
             <li>2026.1.0 &ndash; RIGGWIRE MQL: rebrand of the Lime Mojito / investflow.ru mqlidea fork; adds 80 code-safety inspections and an AI code-healing pipeline.</li>
            </ul>
         ]]>
    </change-notes>

    <idea-version since-build="253.30387"/>

    <depends>com.intellij.modules.lang</depends>

    <actions>
        <action id="NewMQL4File" class="com.limemojito.oss.mql.action.CreateMQL4FileAction">
            <add-to-group group-id="NewGroup" anchor="before" relative-to-action="NewFromTemplate"/>
        </action>
        <action id="NewMQL5File" class="com.limemojito.oss.mql.action.CreateMQL5FileAction">
            <add-to-group group-id="NewGroup" anchor="before" relative-to-action="NewFromTemplate"/>
        </action>
    </actions>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceInterface="com.limemojito.oss.mql.settings.MQL4PluginSettings"
                            serviceImplementation="com.limemojito.oss.mql.settings.MQL4PluginSettingsImpl"/>
        <fileType name="MQL4 File"
                  implementationClass="com.limemojito.oss.mql.MQL4FileType"
                  fieldName="INSTANCE"
                  language="MQL4"
                  extensions="mq4;mqh;mql4"
        />
        <fileType name="MQL5 File"
                  implementationClass="com.limemojito.oss.mql.MQL5FileType"
                  fieldName="INSTANCE"
                  language="MQL4"
                  extensions="mq5;mqh;mql5"
        />

        <lang.parserDefinition language="MQL4"
                               implementationClass="com.limemojito.oss.mql.parser.MQL4ParserDefinition"/>
        <lang.syntaxHighlighterFactory language="MQL4"
                                       implementationClass="com.limemojito.oss.mql.editor.MQL4SyntaxHighlighter$MQL4SyntaxHighlighterFactory"/>
        <lang.commenter language="MQL4" implementationClass="com.limemojito.oss.mql.editor.MQL4Commenter"/>
        <lang.documentationProvider language="MQL4"
                                    implementationClass="com.limemojito.oss.mql.doc.MQL4DocumentationProvider"/>
        <lang.braceMatcher language="MQL4" implementationClass="com.limemojito.oss.mql.editor.MQL4BraceMatcher"/>
        <lang.foldingBuilder language="MQL4" implementationClass="com.limemojito.oss.mql.editor.MQL4FoldingBuilder"/>
        <completion.contributor language="MQL4"
                                implementationClass="com.limemojito.oss.mql.editor.codecompletion.MQL4CompletionContributor"/>

        <!-- sdk -->
        <sdkType implementation="com.limemojito.oss.mql.sdk.MQL4SdkType"/>

        <!--build runner-->
        <programRunner implementation="com.limemojito.oss.mql.runconfig.MQL4CompilerRunner"/>
        <runConfigurationProducer
                implementation="com.limemojito.oss.mql.runconfig.MQL4RunCompilerConfigurationProducer"/>
        <configurationType implementation="com.limemojito.oss.mql.runconfig.MQL4RunCompilerConfigurationType"/>

